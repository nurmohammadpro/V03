# ═══════════════════════════════════════════════════════════════════════════
# V03.TECH ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Security & Secrets (REQUIRED - Generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here-min-32-chars
BETTER_AUTH_SECRET=your-auth-secret-here-min-32-chars
INTERNAL_WORKER_TOKEN=your-internal-token-here-min-32-chars

# Database Configuration (REQUIRED)
DATABASE_URL=postgresql://user:password@host:5432/v03
DATABASE_CONNECTION_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000

# CORS & Security
CORS_ORIGIN=https://v03.tech

# Logging
LOG_LEVEL=info

# Supabase (Optional - for project preview)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Error Tracking (Optional)
SENTRY_DSN=

# Admin Bootstrap (Optional - set to true to bootstrap admin on startup)
BOOTSTRAP_ADMIN_SYSTEM=false
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@v03.tech

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=/var/v03/storage

# GitHub Integration (Optional)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
#
# [ ] Generate unique JWT_SECRET (openssl rand -base64 32)
# [ ] Generate unique BETTER_AUTH_SECRET (openssl rand -base64 32)
# [ ] Generate unique INTERNAL_WORKER_TOKEN (openssl rand -base64 32)
# [ ] Configure DATABASE_URL with production database
# [ ] Set CORS_ORIGIN to production domain
# [ ] Configure Supabase credentials if needed
# [ ] Configure Sentry DSN for error tracking
# [ ] Set LOG_LEVEL based on requirements (production = 'warn')
# [ ] Configure GitHub OAuth if using GitHub integration
# [ ] Run database migrations: pnpm db:push
# [ ] Bootstrap admin account: set BOOTSTRAP_ADMIN_SYSTEM=true on first run
# [ ] Set NODE_ENV=production
# [ ] Use a reverse proxy (nginx) with SSL/TLS
# [ ] Set up proper file logging to /var/log/v03/
# [ ] Configure environment variables in deployment platform
# [ ] Test health check endpoints before going live
#
# Health Check URLs (to test after deployment):
# - GET /api/health           - Basic health check
# - GET /api/health/detailed  - Detailed health (includes DB status)
# - GET /api/health/ready     - Readiness probe for k8s
# - GET /api/health/alive     - Liveness probe for k8s
